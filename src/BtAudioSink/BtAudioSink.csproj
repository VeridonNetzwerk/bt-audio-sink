<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.19041.0</SupportedOSPlatformVersion>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <RootNamespace>BtAudioSink</RootNamespace>
    <AssemblyName>BtAudioSink</AssemblyName>
    <Version>1.0.0</Version>
    <Company>BT Audio Sink</Company>
    <Product>BT Audio Sink</Product>
    <Description>Bluetooth A2DP Audio Sink for Windows - Stream audio from your phone to your PC</Description>
    <Copyright>Copyright © 2024 BT Audio Sink Contributors</Copyright>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <Platforms>x64;ARM64</Platforms>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="H.NotifyIcon.Wpf" Version="2.1.3" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\app.ico" />
  </ItemGroup>

</Project>
