<Window x:Class="BtAudioSink.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:BtAudioSink.Converters"
        xmlns:vm="clr-namespace:BtAudioSink.ViewModels"
        Title="BT Audio Sink"
        Width="460" Height="620"
        MinWidth="380" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        Icon="/Assets/app.ico">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:ConnectionStatusToBrushConverter x:Key="ConnectionStatusToBrush"/>
        <converters:ZeroCountToVisibilityConverter x:Key="ZeroCountToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Window caption buttons (top-right, overlaying everything) -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="100">
            <Button Width="46" Height="32"
                    Content="&#xE949;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="10"
                    ToolTip="Minimize"
                    Click="MinimizeButton_Click"
                    Style="{DynamicResource CaptionButtonStyle}"/>
            <Button Width="46" Height="32"
                    Content="&#xE739;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="10"
                    ToolTip="Maximize"
                    Click="MaximizeButton_Click"
                    Style="{DynamicResource CaptionButtonStyle}"/>
            <Button Width="46" Height="32"
                    Content="&#xE106;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="10"
                    ToolTip="Close"
                    Click="CloseButton_Click"
                    Style="{DynamicResource CloseButtonStyle}"/>
        </StackPanel>

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="{DynamicResource ContentPadding}"
                Background="{DynamicResource CardBackgroundBrush}"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Bluetooth icon -->
                <TextBlock Grid.Column="0"
                           Text="&#xE702;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="28"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="BT Audio Sink"
                               FontSize="{DynamicResource HeaderFontSize}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Bluetooth A2DP Audio Receiver"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content area -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="{DynamicResource ContentPadding}">

            <StackPanel Margin="{DynamicResource ContentPadding}">

                <!-- ========== DEVICES SECTION ========== -->
                <TextBlock Text="Paired Devices"
                           Style="{DynamicResource SectionHeaderStyle}"/>

                <!-- Device list -->
                <ItemsControl ItemsSource="{Binding Devices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DeviceViewModel}">
                            <Border Style="{DynamicResource DeviceItemBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Device icon with status indicator -->
                                    <Grid Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DeviceIcon}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="24"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <!-- Connection status dot -->
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{Binding IsConnected, Converter={StaticResource ConnectionStatusToBrush}}"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Bottom"
                                                 Margin="0,0,-2,-2"/>
                                    </Grid>

                                    <!-- Device name and status -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Connect/Disconnect button -->
                                    <Button Grid.Column="2"
                                            Content="{Binding ButtonText}"
                                            Command="{Binding ToggleConnectionCommand}"
                                            Style="{DynamicResource PrimaryButtonStyle}"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- No devices message -->
                <TextBlock Text="No paired Bluetooth audio devices found.&#x0A;Pair a device in Windows Bluetooth Settings first."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextAlignment="Center"
                           Margin="0,12"
                           LineHeight="20"
                           Visibility="{Binding Devices.Count, Converter={StaticResource ZeroCountToVisibility}}"/>

                <!-- Action buttons -->
                <WrapPanel Margin="0,8,0,0" HorizontalAlignment="Left">
                    <Button Command="{Binding RefreshDevicesCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenBluetoothSettingsCommand}"
                            Style="{DynamicResource SecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Bluetooth Settings"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <!-- ========== SETTINGS SECTION ========== -->
                <StackPanel Margin="{DynamicResource SectionMargin}">
                    <TextBlock Text="Settings"
                               Style="{DynamicResource SectionHeaderStyle}"/>

                    <Border Style="{DynamicResource CardStyle}">
                        <StackPanel>
                            <CheckBox Content="Auto-reconnect on startup"
                                      IsChecked="{Binding AutoReconnect}"
                                      Style="{DynamicResource SettingsCheckBoxStyle}"/>

                            <CheckBox Content="Start minimized to system tray"
                                      IsChecked="{Binding StartMinimized}"
                                      Style="{DynamicResource SettingsCheckBoxStyle}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <CheckBox Content="Run at Windows startup"
                                          IsChecked="{Binding RunAtStartup}"
                                          Visibility="{Binding ShowRunAtStartupOption, Converter={StaticResource BoolToVisibilityConverter}}"
                                          Style="{DynamicResource SettingsCheckBoxStyle}"
                                          Margin="0"/>
                                <Button Command="{Binding ToggleHighPriorityCommand}"
                                        IsEnabled="{Binding RunAtStartup}"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Padding="10,5"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE83D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding RunAtStartupHighPriorityButtonText}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Bottom spacer -->
                <Border Height="8"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="2" Style="{DynamicResource StatusBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Connection indicator -->
                <Ellipse Grid.Column="0"
                         Width="8" Height="8"
                         Fill="{Binding HasConnectedDevice, Converter={StaticResource ConnectionStatusToBrush}}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
    </Grid>
</Window>
