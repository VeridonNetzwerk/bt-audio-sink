<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark mode overrides used on top of Win10/Win11 base themes -->

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#3A3A3A"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F2F2F2"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C8C8C8"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#9B9B9B"/>

    <SolidColorBrush x:Key="SeparatorBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#272727"/>

    <SolidColorBrush x:Key="SubtleHoverBrush" Color="#3A3A3A"/>
</ResourceDictionary>
